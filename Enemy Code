extends CharacterBody2D

@onready var timer: Timer = $Timer
@export var patrol_points: Node2D
@onready var sprite: AnimatedSprite2D = $AnimatedSprite2D
@export var health_amount : int = 3
@export var damage_amount : int = 1
const GRAVITY := 1000
const SPEED := 150

enum State {Idle, Movement}
var current_state: State = State.Movement

var points_positions: Array[Vector2] = []
var current_point_index: int = 0
var current_point: Vector2

var can_Movement: bool = true
var direction: int = -1
var enemy_death_effect = preload("res://FX/enemy_death_effect.tscn")
func _ready():
	if patrol_points == null:
		print("No Patrol Points node assigned")
		return

	for point in patrol_points.get_children():
		points_positions.append(point.global_position)

	if points_positions.size() == 0:
		print("Patrol Points node has no children")
		return

	# Initialize first patrol point
	current_point = points_positions[0]

	timer.wait_time = 3
	timer.one_shot = true
	timer.connect("timeout", Callable(self, "_on_timer_timeout"))


func _physics_process(delta):
	apply_gravity(delta)

	match current_state:
		State.Idle:
			enemy_idle()
		State.Movement:
			enemy_walk()

	enemy_animations()
	move_and_slide()


func apply_gravity(delta):
	velocity.y += GRAVITY * delta


func enemy_idle():
	velocity.x = move_toward(velocity.x, 0, SPEED)


func enemy_walk():
	if not can_Movement:
		velocity.x = 0
		return

	if abs(position.x - current_point.x) > 8:
		velocity.x = direction * SPEED
	else:
		velocity.x = 0
		can_Movement = false
		current_state = State.Idle
		timer.start()

	if current_point.x > position.x:
		direction = 1
		sprite.flip_h = true
	else:
		direction = -1
		sprite.flip_h = false


func enemy_animations():
	if current_state == State.Idle and not can_Movement:
		sprite.play("Idle")
	elif current_state == State.Movement and can_Movement:
		sprite.play("Movement")


func _on_timer_timeout() -> void:
	# Safety check
	if points_positions.size() == 0:
		return

	current_point_index += 1
	if current_point_index >= points_positions.size():
		current_point_index = 0

	current_point = points_positions[current_point_index]
	can_Movement = true
	current_state = State.Movement





func _on_hurtbox_area_entered2(area: Area2D) -> void:
	print("Hurtbox area entered")
	if area.get_parent().has_method("get_damage_amount") :
		var node = area.get_parent() as Node
		health_amount -= node.damage_amount
		print("Health amount:",health_amount)
	if health_amount <= 0 :
		var enemy_death_effect_instance = enemy_death_effect.instantiate() as Node2D
		enemy_death_effect_instance.global_position = global_position
		get_parent().add_child(enemy_death_effect_instance)
		queue_free()
